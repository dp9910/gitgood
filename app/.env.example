# =============================================================================
# GitGood Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local — it is gitignored.
# =============================================================================

# --- Server-side only (never exposed to browser) ---

# Google Gemini API key for AI curriculum generation
GEMINI_API_KEY=

# GitHub Personal Access Token for central curriculum cache repo
GITHUB_PERSONAL_TOKEN=

# Firebase Admin SDK credentials (server-side auth verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Vercel KV (Redis) for server-side rate limiting
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AES-256-GCM encryption key for GitHub tokens (64-char hex = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Client-side (NEXT_PUBLIC_ prefix = included in browser bundle) ---
# Only non-secret Firebase config belongs here

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
